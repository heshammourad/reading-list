generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model books {
  id              Int      @id @default(autoincrement())
  name            String
  author          String
  status          String?  @default("Unread")
  series_id       Int?
  series_order    Decimal? @db.Decimal
  cover_image_url String?

  @@unique([name, author])
}

model charts {
  id            Int      @id @default(autoincrement())
  book_id       Int?
  rank          Int
  weeks_on_list Int
  date          DateTime @db.Date

  @@unique([book_id, date])
}

model series {
  id   Int    @id @default(autoincrement())
  name String @unique
}
